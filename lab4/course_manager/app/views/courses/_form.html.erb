<%= form_with(model: course, class: "mt-3") do |f| %>
  <div class="mb-3">
    <%= f.label :title, "Назва", class: "form-label" %>
    <%= f.text_field :title, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :category, "Категорія", class: "form-label" %>
    <%= f.select :category, @categories, { include_blank: "— Оберіть категорію —" }, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :main_topic, "Основна тема", class: "form-label" %>
    <%= f.text_area :main_topic, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :duration_hours, "Тривалість (год)", class: "form-label" %>
    <%= f.number_field :duration_hours, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :start_date, "Дата початку", class: "form-label" %>
    <%= f.date_field :start_date, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :end_date, "Дата закінчення", class: "form-label" %>
    <%= f.date_field :end_date, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :price, "Ціна", class: "form-label" %>
    <%= f.number_field :price, step: 0.01, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :status, "Статус", class: "form-label" %>
    <%= f.select :status, Course.statuses.keys, {}, class: "form-select" %>
  </div>

  <%= f.submit "Зберегти", class: "btn btn-primary" %>
<% end %>