<!DOCTYPE html>
<html>
  <head>
    <title>Course Manager</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", media: "all" %>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
      <div class="container">
        <a class="navbar-brand" href="/">Course Manager</a>
        <div class="navbar-nav">
          <%= link_to "Всі курси", courses_path, class: "nav-link text-white" %>
          <%= link_to "Активні", active_courses_path, class: "nav-link text-white" %>
          <%= link_to "Категорії", categories_path, class: "nav-link text-white" %>
          <%= link_to "Новий курс", new_course_path, class: "nav-link text-white" %>
        </div>
      </div>
    </nav>

    <div class="container mt-4">
      <% if notice %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>
      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>